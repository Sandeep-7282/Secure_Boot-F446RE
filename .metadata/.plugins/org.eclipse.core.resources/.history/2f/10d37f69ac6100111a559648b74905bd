#include "rsa_verify.h"
#include "uart.h"
#include <string.h>

#define BN_SIZE  256   /* bytes — 2048 bits */

/*----------------------------------------------------------
 * Minimal big-number helpers (little-endian byte arrays)
 *----------------------------------------------------------*/

static void bn_zero(uint8_t *a)
{
    memset(a, 0, BN_SIZE);
}

static void bn_copy(uint8_t *dst, const uint8_t *src)
{
    memcpy(dst, src, BN_SIZE);
}

/* a = 1 */
static void bn_one(uint8_t *a)
{
    bn_zero(a);
    a[BN_SIZE - 1] = 1;
}

/* Compare big-endian: returns -1, 0, +1 */
static int bn_cmp(const uint8_t *a, const uint8_t *b)
{
    for (int i = 0; i < BN_SIZE; i++) {
        if (a[i] < b[i]) return -1;
        if (a[i] > b[i]) return  1;
    }
    return 0;
}

/* result = (a + b) mod n  — all big-endian, BN_SIZE bytes */
static void bn_addmod(uint8_t *result,
                      const uint8_t *a,
                      const uint8_t *b,
                      const uint8_t *n)
{
    uint16_t carry = 0;
    uint8_t  tmp[BN_SIZE];

    for (int i = BN_SIZE - 1; i >= 0; i--) {
        uint16_t sum = (uint16_t)a[i] + b[i] + carry;
        tmp[i] = (uint8_t)(sum & 0xFF);
        carry  = sum >> 8;
    }

    /* subtract n if tmp >= n */
    if (carry || bn_cmp(tmp, n) >= 0) {
        uint16_t borrow = 0;
        for (int i = BN_SIZE - 1; i >= 0; i--) {
            int16_t diff = (int16_t)tmp[i] - n[i] - borrow;
            if (diff < 0) { diff += 256; borrow = 1; }
            else          { borrow = 0; }
            result[i] = (uint8_t)diff;
        }
    } else {
        bn_copy(result, tmp);
    }
}

/* result = (a * b) mod n  — schoolbook multiplication */
static void bn_mulmod(uint8_t *result,
                      const uint8_t *a,
                      const uint8_t *b,
                      const uint8_t *n)
{
    uint8_t R[BN_SIZE];
    uint8_t A[BN_SIZE];
    bn_zero(R);
    bn_copy(A, a);

    for (int byte_i = BN_SIZE - 1; byte_i >= 0; byte_i--) {
        for (int bit = 7; bit >= 0; bit--) {
            if ((b[byte_i] >> bit) & 1)
                bn_addmod(R, R, A, n);
            /* double A mod n */
            bn_addmod(A, A, A, n);
        }
    }
    bn_copy(result, R);
}

/*----------------------------------------------------------
 * Modular exponentiation: result = base^exp mod n
 * exp is a plain uint32_t (65537)
 *----------------------------------------------------------*/
static void bn_powmod(uint8_t *result,
                      const uint8_t *base,
                      uint32_t       exp,
                      const uint8_t *n)
{
    uint8_t R[BN_SIZE];
    uint8_t B[BN_SIZE];
    bn_one(R);
    bn_copy(B, base);

    while (exp > 0) {
        if (exp & 1)
            bn_mulmod(R, R, B, n);
        bn_mulmod(B, B, B, n);
        exp >>= 1;
    }
    bn_copy(result, R);
}

/*----------------------------------------------------------
 * PKCS#1 v1.5 SHA-256 DigestInfo prefix (15 bytes)
 *----------------------------------------------------------*/
static const uint8_t PKCS1_SHA256_PREFIX[19] = {
    0x00, 0x30, 0x31, 0x30, 0x0d, 0x06, 0x09,
    0x60, 0x86, 0x48, 0x01, 0x65, 0x03, 0x04,
    0x02, 0x01, 0x05, 0x00, 0x04
};

/*----------------------------------------------------------
 * RSA PKCS#1 v1.5 verify
 * signature : 256 bytes, big-endian
 * hash      : 32 bytes SHA-256
 * modulus   : 256 bytes, big-endian
 * exponent  : 65537
 *----------------------------------------------------------*/
RSA_Status rsa_verify(const uint8_t *signature,
                      const uint8_t *hash,
                      const uint8_t *modulus,
                      uint32_t       exponent)
{
    uint8_t decrypted[BN_SIZE];

    /* Step 1: RSA public operation — decrypt signature */
    bn_powmod(decrypted, signature, exponent, modulus);

    /*
     * Step 2: Verify PKCS#1 v1.5 padding structure
     * Expected layout (256 bytes total):
     * 0x00 0x01 [0xFF padding...] 0x00 [DigestInfo prefix] [32-byte hash]
     */
    /* Temporary debug — add right after bn_to_bytes call in rsa_verify.c */
    char dbg[64];
    uart_send_str("[RSA] Decrypted bytes[248..255]: ");
    for (int i = 248; i < 256; i++) {
        uint8_t hi = (decrypted[i] >> 4) & 0xF;
        uint8_t lo = (decrypted[i])      & 0xF;
        dbg[(i-248)*3]   = hi < 10 ? '0'+hi : 'A'+(hi-10);
        dbg[(i-248)*3+1] = lo < 10 ? '0'+lo : 'A'+(lo-10);
        dbg[(i-248)*3+2] = ' ';
    }
    dbg[24] = '\r'; dbg[25] = '\n'; dbg[26] = '\0';
    uart_send_str(dbg);
    if (decrypted[0] != 0x00) return RSA_VERIFY_FAIL;
    if (decrypted[1] != 0x01) return RSA_VERIFY_FAIL;

    /* Find 0x00 separator after 0xFF padding */
    int sep = -1;
    for (int i = 2; i < BN_SIZE - 32; i++) {
        if (decrypted[i] == 0x00) { sep = i; break; }
        if (decrypted[i] != 0xFF) return RSA_VERIFY_FAIL;
    }
    if (sep == -1) return RSA_VERIFY_FAIL;

    /* Step 3: Verify DigestInfo prefix */
    if (memcmp(&decrypted[sep], PKCS1_SHA256_PREFIX,
               sizeof(PKCS1_SHA256_PREFIX)) != 0)
        return RSA_VERIFY_FAIL;

    /* Step 4: Compare hash */
    int hash_offset = sep + sizeof(PKCS1_SHA256_PREFIX);
    if (memcmp(&decrypted[hash_offset], hash, 32) != 0)
        return RSA_VERIFY_FAIL;

    return RSA_VERIFY_OK;
}

